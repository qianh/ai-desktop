{
  "name": "appscope",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "AppScope — macOS app/page launcher + per-session HTTP(S) capture client (Tauri v2 + React)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "verify:mvp-capture": "cargo run --manifest-path src-tauri/Cargo.toml --bin verify_mvp_capture",
    "test": "vitest run"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^3.0.5"
  }
}
